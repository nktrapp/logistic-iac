# Use the image published by the package-service release workflow to ECR.
# Repository is created by envs/bootstrap and shared across environments.
service_image = "<account-id>.dkr.ecr.us-east-1.amazonaws.com/furb-logistics/package-service:<tag>"

desired_count = 1

# ---------------------------------------------------------------------------
# MongoDB: two ways to wire it.
#
# (A) DEFAULT - point to data you already provisioned (create_mongodb = false).
# ---------------------------------------------------------------------------
mongodb_uri = "mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/package_db?retryWrites=true&w=majority"

# ---------------------------------------------------------------------------
# (B) Let Terraform manage the Atlas M0 cluster. Flip the toggle, fill the
#     credentials, set the names to match what you already have, then
#     `terraform import` the existing resources (see module README).
# ---------------------------------------------------------------------------
# create_mongodb        = true
# atlas_public_key      = "<atlas-api-public-key>"
# atlas_private_key     = "<atlas-api-private-key>"
# atlas_org_id          = "<atlas-org-id>"
# mongodb_project_name  = "furb-logistics-package-service"
# mongodb_cluster_name  = "package"
# mongodb_database_name = "package_db"
# mongodb_db_username   = "package_app"
# mongodb_db_password   = "<existing-or-blank-to-generate>"
