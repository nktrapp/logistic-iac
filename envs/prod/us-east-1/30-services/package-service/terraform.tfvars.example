# Use an immutable tag in prod. Do not use latest.
service_image = "<account-id>.dkr.ecr.us-east-1.amazonaws.com/furb-logistics/package-service:<version>"

desired_count = 1

# MongoDB is provisioned by 20-data/package-service, which publishes the
# connection secret ARN to SSM. This stack reads it from SSM automatically —
# nothing to configure here. Apply the 20-data stack first.
