# Use an immutable tag in prod. Do not use latest.
service_image = "<account-id>.dkr.ecr.us-east-1.amazonaws.com/furb-logistics/package-service:<version>"

# MongoDB Atlas (M0 free) connection string. Keep the real value out of git.
mongodb_uri = "mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/package_db?retryWrites=true&w=majority"

desired_count = 1
