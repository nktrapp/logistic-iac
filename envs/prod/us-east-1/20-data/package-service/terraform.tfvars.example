# MongoDB Atlas (M0 free) managed by Terraform. Fill the API credentials below;
# project/cluster/database names default in variables.tf and the password is
# generated when left blank. This stack creates the Secrets Manager secret and
# publishes its ARN to SSM, where 30-services/package-service reads it. Keep
# credentials out of git.
#
# Already created the cluster by hand? `terraform import` it once (see module
# README) so it is adopted instead of recreated.
atlas_public_key  = "<atlas-api-public-key>"
atlas_private_key = "<atlas-api-private-key>"
atlas_org_id      = "<atlas-org-id>"
# mongodb_db_password = "<existing-password-or-leave-blank-to-generate>"
